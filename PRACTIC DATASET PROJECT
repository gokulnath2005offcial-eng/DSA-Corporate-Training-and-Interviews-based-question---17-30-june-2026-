        "\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "df_clean = df[~((df[['precipitation','temp_max','temp_min','wind']] < (Q1 - 1.5 * IQR)) |\n",
        "                (df[['precipitation','temp_max','temp_min','wind']] > (Q3 + 1.5 * IQR))).any(axis=1)]\n",
        "\n",
        "print(\"Original Shape :\", df.shape)\n",
        "print(\"New Shape :\", df_clean.shape)\n",
